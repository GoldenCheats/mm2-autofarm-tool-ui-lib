-- ==================== ADVANCED YARHM COMBAT MODULE ====================

local function getRoles()
    local success, data = pcall(function()
        return ReplicatedStorage:FindFirstChild("GetPlayerData", true):InvokeServer()
    end)
    return success and data or {}
end

local function findMurderer()
    local data = getRoles()
    for name, pData in pairs(data) do
        if pData.Role == "Murderer" and not pData.Dead then
            local target = Players:FindFirstChild(name)
            if target then return target end
        end
    end
    return nil
end

local function findSheriff()
    local data = getRoles()
    for name, pData in pairs(data) do
        if (pData.Role == "Sheriff" or pData.Role == "Hero") and not pData.Dead then
            local target = Players:FindFirstChild(name)
            if target then return target end
        end
    end
    return nil
end

-- HIGHEST TIER PREDICTION MATH
local function getUltimatePrediction(target)
    local char = target.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return nil end

    local hrp = char.HumanoidRootPart
    local velocity = hrp.AssemblyLinearVelocity
    local position = hrp.Position

    -- Get real-time ping accurately
    local ping = 0.05
    pcall(function()
        ping = Stats.Network.ServerStatsItem["Data Ping"]:GetValue() / 1000
    end)

    -- By offsetting the origin to right above their head, distance is ~4 studs.
    -- Time-to-impact (TTI) is virtually zero, so we ONLY compensate for Network Ping & Server Tick Delay
    local serverTickDelay = 0.033
    local networkDelay = ping + serverTickDelay

    -- Kinematic prediction: Pos = Pos + (Vel * Time)
    local predictedPos = position + (velocity * networkDelay)

    -- Arc Physics Compensation (If they are jumping or falling)
    if velocity.Y ~= 0 then
        -- Subtract gravity pull over the delay time: 0.5 * a * t^2
        local gravity = workspace.Gravity
        predictedPos = predictedPos + Vector3.new(0, 0.5 * -gravity * (networkDelay ^ 2), 0)
    end

    -- Bias to Upper Torso for maximum hitbox volume margin
    return predictedPos + Vector3.new(0, 1.2, 0)
end

local function executeShot(target)
    local gun = LocalPlayer.Character:FindFirstChild("Gun") or LocalPlayer.Backpack:FindFirstChild("Gun")
    if not gun then return false end

    if not LocalPlayer.Character:FindFirstChild("Gun") then
        LocalPlayer.Character.Humanoid:EquipTool(gun)
    end

    local predictedTargetPos = getUltimatePrediction(target)
    if not predictedTargetPos then return false end

    -- EXPLOIT: We set the bullet's origin immediately next to them (bypassing travel time) and aim directly at the mathematically predicted position.
    local bulletOrigin = CFrame.new(target.Character.HumanoidRootPart.Position + Vector3.new(0, 4, 0))
    local hitCFrame = CFrame.new(predictedTargetPos)

    gun.Shoot:FireServer(bulletOrigin, hitCFrame)
    return true
end

