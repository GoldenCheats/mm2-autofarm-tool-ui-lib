UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end

    if input.KeyCode == instakillKey then
        if findSheriff() == LocalPlayer then
            local murd = findMurderer()
            if murd then executeShot(murd) end
        end
    elseif input.KeyCode == autoShootKey then
        autoShootEnabled = not autoShootEnabled
        -- If UI library supports setting toggle state visually, you'd call it here.
        print("[Combat] Auto Shoot is now: " .. tostring(autoShootEnabled))
    end
end)

-- Auto Shoot Loop
RunService.Heartbeat:Connect(function()
    if not autoShootEnabled then return end
    if findSheriff() ~= LocalPlayer then return end

    local gun = LocalPlayer.Character:FindFirstChild("Gun")
    if not gun then return end -- Only auto-shoot if gun is actively equipped in hand

    local murd = findMurderer()
    if murd then
        executeShot(murd)
    end
end)

